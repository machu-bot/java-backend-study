---
import Base from '../layouts/Base.astro';
import { allQuestions } from '../lib/content';
const total = allQuestions().length;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title="대시보드" active="dashboard">
  <section class="hero" style="padding-top: 24px;">
    <div class="eyebrow">/ Dashboard</div>
    <h1>대시보드</h1>
    <p class="lead">내 학습 진도, XP, streak, 배지를 한 곳에서 확인합니다.</p>
  </section>

  <div id="dashboard-root" data-total={total}></div>
  <meta name="x-base-url" content={base} />

  <div class="dash-card" style="margin-top: 24px;">
    <h3>Reset</h3>
    <p class="muted tiny" style="margin-bottom: 12px;">진도를 모두 리셋합니다. 되돌릴 수 없습니다.</p>
    <button class="btn btn-err" data-reset>진도 초기화</button>
  </div>
</Base>

<script>
  import { load, reset } from '../lib/store';
  import { allQuestions, chapters } from '../lib/content';
  import extraChaptersData from '../lib/extra-chapters.json';
  const base = '__BASE_URL_PLACEHOLDER__';
  const meta = document.querySelector('meta[name="x-base-url"]');
  const realBase = meta?.getAttribute('content') || base;

  const root = document.getElementById('dashboard-root');
  if (root) {
    const total = parseInt(root.dataset.total || '0', 10);
    const state = load();
    const answered = Object.values(state.answered);
    const solved = answered.filter((a) => a.correct).length;
    const accuracy = answered.length === 0 ? 0 : Math.round(solved / answered.length * 100);
    const allQs = allQuestions();
    const allChapters = [...chapters, ...(extraChaptersData as any[])];

    const allBadges = [
      { id: 'first-correct', name: 'FIRST HIT', desc: '문제 하나를 맞힘' },
      { id: 'five-correct', name: 'FIVE CLEAR', desc: '정답 5개 달성' },
      { id: 'streak-3', name: '3-DAY STREAK', desc: '3일 연속 학습' },
      { id: 'streak-7', name: '7-DAY STREAK', desc: '7일 연속 학습' },
    ];

    const segmented = (pct: number, segCount = 16) => {
      const filled = Math.round((pct / 100) * segCount);
      let html = `<div class="segmented" role="img" aria-label="진행도 ${pct}%">`;
      for (let k = 0; k < segCount; k++) {
        html += `<span class="seg${k < filled ? ' on' : ''}" data-state="neutral"></span>`;
      }
      html += '</div>';
      return html;
    };

    root.innerHTML = `
      <div class="stat-grid">
        <div class="stat">
          <div class="label">Streak</div>
          <div class="value">${state.streak.current}<span class="unit">일</span></div>
        </div>
        <div class="stat">
          <div class="label">Best Streak</div>
          <div class="value">${state.streak.best}<span class="unit">일</span></div>
        </div>
        <div class="stat">
          <div class="label">XP</div>
          <div class="value">${state.xp}</div>
        </div>
        <div class="stat">
          <div class="label">Solved</div>
          <div class="value">${solved}<span class="unit">/ ${total}</span></div>
        </div>
        <div class="stat">
          <div class="label">Accuracy</div>
          <div class="value">${accuracy}<span class="unit">%</span></div>
        </div>
      </div>

      <div class="dash-card">
        <h3>Badges</h3>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          ${allBadges.map((b) => {
            const unlocked = state.badges.includes(b.id);
            return `<span class="badge ${unlocked ? '' : 'locked'}" title="${b.desc}">${b.name}</span>`;
          }).join('')}
        </div>
      </div>

      <div class="dash-card">
        <h3>Chapter Progress</h3>
        <div style="display:grid; gap:1px; background: var(--border); border: 1px solid var(--border);">
          ${allChapters.map((c, i) => {
            const inC = allQs.filter((q) => q.chapter === c.id);
            const done = inC.filter((q) => state.answered[q.id]?.correct).length;
            const pct = inC.length ? Math.round(done / inC.length * 100) : 0;
            return `
              <a class="track-card" href="${realBase}tracks/${c.id}/" style="padding: 18px 20px;">
                <span class="track-num">0${i + 1}</span>
                <h3>${c.title}</h3>
                <div class="meta">
                  <span class="tiny">${done} / ${inC.length} CORRECT</span>
                  <span class="tiny">${pct}%</span>
                </div>
                <div class="progress-wrap" style="margin-top: 10px;">
                  ${segmented(pct)}
                </div>
              </a>
            `;
          }).join('')}
        </div>
      </div>
    `;

    document.querySelector<HTMLButtonElement>('[data-reset]')?.addEventListener('click', () => {
      if (confirm('진도를 모두 초기화할까요? 되돌릴 수 없습니다.')) {
        reset();
        location.reload();
      }
    });
  }
</script>
