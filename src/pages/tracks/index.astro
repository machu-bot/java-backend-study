---
import Base from '../../layouts/Base.astro';
import { chapters, allQuestions } from '../../lib/content';
import extraChaptersData from '../../lib/extra-chapters.json';
import { chapterProgress, defaultState } from '../../lib/store';
const qs = allQuestions();
const allChapters = [...chapters, ...(extraChaptersData as any[])];
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title="트랙" active="tracks">
  <section class="hero" style="padding-top: 24px;">
    <h1>트랙</h1>
    <p class="lead">챕터를 골라 풀거나, 아래에서 진행도를 확인합니다.</p>
  </section>

  <div class="track-grid">
    {
      allChapters.map((c, i) => {
        const inC = qs.filter((q) => q.chapter === c.id);
        const prog = Math.round(
          chapterProgress(defaultState(), qs, c.id) * 100
        );
        const segCount = 16;
        const filled = Math.round((prog / 100) * segCount);
        return (
          <a class="track-card" href={`${base}tracks/${c.id}/`}>
            <span class="track-num">0{i + 1} / {String(allChapters.length).padStart(2, '0')}</span>
            <h3>{c.title}</h3>
            <p>{c.blurb}</p>
            <div class="meta">
              <span class="tiny">{inC.length} Q · {c.estMinutes} MIN</span>
              <span class="tiny">{prog}%</span>
            </div>
            <div class="segmented progress-wrap" role="img" aria-label={`진행도 ${prog}%`}>
              {Array.from({ length: segCount }).map((_, k) => (
                <span class={`seg${k < filled ? ' on' : ''}`} data-state="neutral" />
              ))}
            </div>
          </a>
        );
      })
    }
  </div>
</Base>
