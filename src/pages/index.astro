---
import Base from '../layouts/Base.astro';
import { chapters, allQuestions } from '../lib/content';
import { defaultState, chapterProgress, load } from '../lib/store';

const questions = allQuestions();
const total = questions.length;
const initial = defaultState();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const today = new Date().toISOString().slice(0, 10);
---

<Base title="홈" active="home">
  <section class="hero">
    <span class="pill"><span class="dot"></span> {today} · 매일 한 문제</span>
    <div class="dot-grid-subtle" style="height: 1px; margin: 8px 0 0;" aria-hidden="true"></div>
    <h1>백엔드,<br /><span class="grad">매일 조금씩</span><br />풀면서 익힙니다.</h1>
    <p class="lead">
      읽고 외우는 대신 직접 풀어봅니다. {total}개의 인터랙티브 문제로
      Java·객체지향·Spring Boot의 기반을 다지고, 오늘도 streak를 이어가세요.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={`${base}practice/`}>문제 풀기 시작 →</a>
      <a class="btn btn-ghost" href={`${base}about/`}>어떻게 공부하나요?</a>
    </div>

    <div class="stat-grid">
      <div class="stat">
        <div class="label">Streak</div>
        <div class="value" data-bind="streak">{initial.streak.current}<span class="unit">일</span></div>
      </div>
      <div class="stat">
        <div class="label">XP</div>
        <div class="value" data-bind="xp">0</div>
      </div>
      <div class="stat">
        <div class="label">푼 문제</div>
        <div class="value" data-bind="solved">0<span class="unit">/ {total}</span></div>
      </div>
      <div class="stat">
        <div class="label">배지</div>
        <div class="value" data-bind="badges">0</div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>트랙</h2>
      <a href={`${base}tracks/`}>전체 보기 →</a>
    </div>
    <div class="track-grid">
      {
        chapters.map((c, i) => {
          const prog = Math.round(
            chapterProgress(defaultState(), questions, c.id) * 100
          );
          const segCount = 16;
          const filled = Math.round((prog / 100) * segCount);
          return (
            <a class="track-card" href={`${base}tracks/${c.id}/`}>
              <span class="track-num">0{i + 1} / {String(chapters.length).padStart(2, '0')}</span>
              <h3>{c.title}</h3>
              <p>{c.blurb}</p>
              <div class="meta">
                <span class="tiny">{c.estMinutes} MIN</span>
                <span class="tiny">{prog}%</span>
              </div>
              <div class="segmented progress-wrap" role="img" aria-label={`진행도 ${prog}%`}>
                {Array.from({ length: segCount }).map((_, k) => (
                  <span class={`seg${k < filled ? ' on' : ''}`} data-state="neutral" />
                ))}
              </div>
            </a>
          );
        })
      }
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>왜 이 사이트인가</h2>
    </div>
    <ul class="why">
      <li>
        <strong>읽기보다 풀기.</strong> 모든 챕터는 짧은 카드 + 즉시 채점
        문제로 구성됩니다.
      </li>
      <li>
        <strong>매일의 작은 의지.</strong> Streak이 끊기지 않도록 가볍게 한
        문제씩.
      </li>
      <li>
        <strong>회사에서 쓰는 코드를 가정.</strong> 면접·리뷰에서 자주 보이는
        패턴 위주의 문제.
      </li>
      <li>
        <strong>데이터는 내 브라우저에.</strong> 서버 없이 localStorage에
        저장되니 부담 없이 시작할 수 있어요.
      </li>
    </ul>
  </section>
</Base>

<script>
  import { load } from '../lib/store';
  const state = load();
  const total = {total};
  const solved = Object.values(state.answered).filter((a) => a.correct).length;
  const render = (k: string, html: string) => {
    const el = document.querySelector(`[data-bind="${k}"]`);
    if (el) el.innerHTML = html;
  };
  render('streak', `${state.streak.current}<span class="unit">일</span>`);
  render('xp', String(state.xp));
  render('solved', `${solved}<span class="unit">/ ${total}</span>`);
  render('badges', String(state.badges.length));
</script>
